@using VehicleShowroom.Data.Models
@model IEnumerable<Vehicle>

<div class="container my-4">
    <div class="row">
        @foreach (var vehicle in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card vehicle-card h-100">
                    <img src="@vehicle.ImageUrl" alt="@vehicle.Make" class="img-thumbnail vehicle-img mt-2" />
                    <div class="card-body">
                        <h5 class="card-title">@vehicle.Make @vehicle.Model</h5>
                        <p class="card-text">
                            <strong>Type:</strong> @vehicle.VehicleType<br />
                            <strong>Year:</strong> @vehicle.Year<br />
                            <strong>Price:</strong> @vehicle.Price<br />
                            <strong>Color:</strong> @vehicle.Color<br />
                            <strong>Fuel Type:</strong> @vehicle.FuelType<br />
                        </p>
                    </div>
                    <a asp-action="Details" asp-route-id="@vehicle.VehicleId" class="btn btn-vehicle-details">Details</a>
                </div>
            </div>
        }
    </div>
</div>
