@using static VehicleShowroom.Common.ApplicationConstants
@{
    int currentYear = DateTime.UtcNow.Year;
    string footerYear = (ReleaseYear == currentYear) ?
        $"{currentYear}" : $"{ReleaseYear} - {currentYear}";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VehicleShowroom.Web.styles.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark custom-navbar shadow-sm">
            <div class="container-fluid">

                <a class="navbar-brand fw-bold text-success"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">
                    VehicleShowroom
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Vehicle"
                               asp-action="Index">All Vehicles</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Car"
                               asp-action="Index">Cars</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="SuperCar"
                               asp-action="Index">SuperCars</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Motorcycle"
                               asp-action="Index">Motorcycles</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Bus"
                               asp-action="Index">Buses</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Truck"
                               asp-action="Index">Trucks</a>
                        </li>

                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-success"
                                   asp-controller="FavoritesVehicle"
                                   asp-action="Index">
                                    My Favorites
                                </a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer border-top text-muted mt-5">
        <div class="container text-center py-3">
            &copy; @footerYear - VehicleShowroom
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
