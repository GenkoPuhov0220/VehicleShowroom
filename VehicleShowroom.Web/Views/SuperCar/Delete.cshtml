@using Microsoft.AspNetCore.Identity
@using VehicleShowroom.Data.Models
@inject SignInManager<ApplicationUser> SingInManager
@inject UserManager<ApplicationUser> UserManager
@model SuperCarDeleteViewModel
@{
    ViewData["Title"] = "Vehicle Delete";
}
@if (User.IsInRole("Admin"))
{   
<div class="container vehicle-delete mt-5">
    <div class="text-center mb-4">
        <h1 class="text-danger">Delete Vehicle</h1>
        <p class="lead text-light">Are you sure you want to delete this vehicle?</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm bg-dark text-light">
                <div class="card-body">
                    <h4 class="card-title text-success">Vehicle Details</h4>
                    <div class="mb-3">
                        <p><strong>Vehicle Type:</strong> @Model.VehicleType</p>
                        <p><strong>Make:</strong> @Model.Make</p>
                        <p><strong>Model:</strong> @Model.Model</p>
                        <p><strong>Year:</strong> @Model.Year</p>
                        <p><strong>Price:</strong> @Model.Price</p>
                        <p><strong>Color:</strong> @Model.Color</p>
                        <p><strong>Fuel Type:</strong> @Model.FuelType</p>
                    </div>
                    <div class="text-center">
                        <img src="@Model.ImageUrl" alt="Vehicle Image" class="img-fluid rounded shadow-sm vehicle-image" style="max-width: 300px;" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model?.SuperCarId != null)
    {
        <div class="row justify-content-center mt-4">
            <div class="col-md-8">
                <div class="card shadow-sm bg-dark text-light">
                    <div class="card-body">
                        <h4 class="card-title text-success">SuperCar Details</h4>
                        <div class="mb-3">
                            <p><strong>Kilometers:</strong> @Model.Kilometers</p>
                            <p><strong>Description:</strong> @Model.NumberOfDoors</p>
                            <p><strong>Description:</strong> @Model.Description</p>
                            <p><strong>Transmission:</strong> @Model.Transmission</p>
                            <p><strong>Horse Power:</strong> @Model.HorsePower</p>
                            <p><strong>Horse Power:</strong> @Model.Weight</p>
                            <p><strong>Horse Power:</strong> @Model.MaxSpeed</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row justify-content-center mt-4">
        <div class="col-md-8 text-center">
            <form asp-action="ConfirmedDelete" method="post">
                <input type="hidden" name="id" value="@Model?.VehicleId" />
                <button type="submit" class="btn btn-delete">Delete</button>
                <a asp-action="Index" class="btn btn-back">Cancel</a>
            </form>
        </div>
    </div>
</div>
}
