@model AddVehicleViewModel

@{
    ViewData["Title"] = "Add New Vehicle";
}

<h2 class="text-success">@ViewData["Title"]</h2>

<form asp-action="AddVehicle" method="post" enctype="multipart/form-data" class="vehicle-form">

    <div class="mb-3">
        <label asp-for="@Model.VehicleType" class="form-label">Vehicle Type</label>
        <select asp-for="@Model.VehicleType" class="form-control vehicle-select" id="vehicleType">
            <option value="Car">Car</option>
            <option value="Bus">Bus</option>
            <option value="Motorcycle">Motorcycle</option>
            <option value="SuperCar">SuperCar</option>
            <option value="Truck">Truck</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Make" class="form-label">Make</label>
        <input asp-for="Make" class="form-control" />
        <span asp-validation-for="Make" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Model" class="form-label">Model</label>
        <input asp-for="Model" class="form-control" />
        <span asp-validation-for="Model" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Year" class="form-label">Year</label>
        <input asp-for="Year" class="form-control" />
        <span asp-validation-for="Year" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label">Price</label>
        <input asp-for="Price" type="number" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Color" class="form-label">Color</label>
        <input asp-for="Color" class="form-control" />
        <span asp-validation-for="Color" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="FuelType" class="form-label">Fuel Type</label>
        <input asp-for="FuelType" class="form-control" />
        <span asp-validation-for="FuelType" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ImageUrl" class="form-label">Image URL</label>
        <input asp-for="ImageUrl" class="form-control" />
        <span asp-validation-for="ImageUrl" class="text-danger"></span>
    </div>

    <!-- Car Fields -->
    <div id="carFields" style="display:none;">
        <h4 class="text-success">Car Details</h4>
        <div class="mb-3">
            <label asp-for="Kilometers" class="form-label">Kilometers</label>
            <input asp-for="Kilometers" type="number" class="form-control" />
            <span asp-validation-for="Kilometers" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="NumberOfDoors" class="form-label">Number of Doors</label>
            <input asp-for="NumberOfDoors" type="number" class="form-control" />
            <span asp-validation-for="NumberOfDoors" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="CarDescription" class="form-label">Description</label>
            <input asp-for="CarDescription" class="form-control" />
            <span asp-validation-for="CarDescription" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="CarTransmission" class="form-label">Transmission</label>
            <input asp-for="CarTransmission" class="form-control" />
            <span asp-validation-for="CarTransmission" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="CarHorsePower" class="form-label">Horse Power</label>
            <input asp-for="CarHorsePower" type="number" class="form-control" />
            <span asp-validation-for="CarHorsePower" class="text-danger"></span>
        </div>
    </div>

    <!-- Bus Fields -->
    <div id="busFields" style="display:none;">
        <h4 class="text-success">Bus Details</h4>
        <div class="mb-3">
            <label asp-for="Capacity" class="form-label">Capacity</label>
            <input asp-for="Capacity" type="number" class="form-control" />
            <span asp-validation-for="Capacity" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="BusDescription" class="form-label">Description</label>
            <input asp-for="BusDescription" class="form-control" />
            <span asp-validation-for="BusDescription" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="BusTransmission" class="form-label">Transmission</label>
            <input asp-for="BusTransmission" class="form-control" />
            <span asp-validation-for="BusTransmission" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="BusHorsePower" class="form-label">Horse Power</label>
            <input asp-for="BusHorsePower" type="number" class="form-control" />
            <span asp-validation-for="BusHorsePower" class="text-danger"></span>
        </div>
    </div>

    <!-- Motorcycle Fields -->
    <div id="motorcycleFields" style="display:none;">
        <h4 class="text-success">Motorcycle Details</h4>
        <div class="mb-3">
            <label asp-for="Kw" class="form-label">Kilowatts (Kw)</label>
            <input asp-for="Kw" type="number" class="form-control" />
            <span asp-validation-for="Kw" class="text-danger"></span>
        </div>
    </div>

    <!-- SuperCar Fields -->
    <div id="superCarFields" style="display:none;">
        <h4 class="text-success">SuperCar Details</h4>
        <div class="mb-3">
            <label asp-for="SuperCarKilometers" class="form-label">Kilometers</label>
            <input asp-for="SuperCarKilometers" type="number" class="form-control" />
            <span asp-validation-for="SuperCarKilometers" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="SuperCarDoors" class="form-label">Number of Doors</label>
            <input asp-for="SuperCarDoors" type="number" class="form-control" />
            <span asp-validation-for="SuperCarDoors" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="SuperCarDescription" class="form-label">Description</label>
            <input asp-for="SuperCarDescription" class="form-control" />
            <span asp-validation-for="SuperCarDescription" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="SuperCarTransmission" class="form-label">Transmission</label>
            <input asp-for="SuperCarTransmission" class="form-control" />
            <span asp-validation-for="SuperCarTransmission" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="SuperCarHorsePower" class="form-label">Horse Power</label>
            <input asp-for="SuperCarHorsePower" type="number" class="form-control" />
            <span asp-validation-for="SuperCarHorsePower" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="MaxSpeed" class="form-label">Max Speed</label>
            <input asp-for="MaxSpeed" class="form-control" />
            <span asp-validation-for="MaxSpeed" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Weight" class="form-label">Weight</label>
            <input asp-for="Weight" class="form-control" />
            <span asp-validation-for="Weight" class="text-danger"></span>
        </div>
    </div>

    <!-- Truck Fields -->
    <div id="truckFields" style="display:none;">
        <h4 class="text-success">Truck Details</h4>
        <div class="mb-3">
            <label asp-for="CargoCapacity" class="form-label">Cargo Capacity</label>
            <input asp-for="CargoCapacity" type="number" class="form-control" />
            <span asp-validation-for="CargoCapacity" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="EuroNumber" class="form-label">Euro Number</label>
            <input asp-for="EuroNumber" class="form-control" />
            <span asp-validation-for="EuroNumber" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="TruckDescription" class="form-label">Description</label>
            <input asp-for="TruckDescription" class="form-control" />
            <span asp-validation-for="TruckDescription" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="TruckTransmission" class="form-label">Transmission</label>
            <input asp-for="TruckTransmission" class="form-control" />
            <span asp-validation-for="TruckTransmission" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="TruckHorsePower" class="form-label">Horse Power</label>
            <input asp-for="TruckHorsePower" type="number" class="form-control" />
            <span asp-validation-for="TruckHorsePower" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-add-vehicle">Add Vehicle</button>
        <a asp-action="Index" class="btn btn-add-vehicle">Back</a>
    </div>
</form>

@section Scripts {
    <script>
        document.getElementById("vehicleType").addEventListener("change", function () {
            var vehicleType = this.value;

            document.getElementById("carFields").style.display = "none";
            document.getElementById("busFields").style.display = "none";
            document.getElementById("motorcycleFields").style.display = "none";
            document.getElementById("superCarFields").style.display = "none";
            document.getElementById("truckFields").style.display = "none";

            if (vehicleType === "Car") document.getElementById("carFields").style.display = "block";
            else if (vehicleType === "Bus") document.getElementById("busFields").style.display = "block";
            else if (vehicleType === "Motorcycle") document.getElementById("motorcycleFields").style.display = "block";
            else if (vehicleType === "SuperCar") document.getElementById("superCarFields").style.display = "block";
            else if (vehicleType === "Truck") document.getElementById("truckFields").style.display = "block";
        });
    </script>
}
